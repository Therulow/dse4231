. 
. use "$path/crime_potsv4.dta", clear

. 
. xtset FIPS YEAR

Panel variable: FIPS (strongly balanced)
 Time variable: YEAR, 1995 to 2019
         Delta: 1 unit

. 
. global tvar1 STt_*

. global tvar2 STt_* STtsq_*

. global xvar1 GOV_DEM STATE_DEM POV_RATE UNRATE POP_DENSITY AVG_MED AVG_REC lnCIG lnAL
> COHOL lnPOLICE lnREALINC

. 
. * Dynamic treatment variables matching the published Table 3 structure
. global MEDvar D_MED_P0 D_MED_M1 D_MED_M2 D_MED_M3 D_MED_M4 D_MED_M5F

. global RECvar D_REC_P0 D_REC_M1 D_REC_M2 D_REC_M3 D_REC_M4 D_REC_M5F

. 
. capture program drop run_dyn

. program define run_dyn
  1.     syntax varname, prefix(name)
  2. 
.     di "============================================================"
  3.     di "Outcome: `varlist'"
  4.     di "============================================================"
  5. 
.     eststo clear
  6. 
.     * ---------------- Model 1 ----------------
.     di " "
  7.     di "Model 1: FE + covariates"
  8.     areg `varlist' $MEDvar $RECvar $xvar1 i.YEAR, absorb(FIPS) vce(robust)
  9.     estimates store `prefix'7
 10. 
.     test (D_MED_P0 = D_MED_M1) ///
>          (D_MED_M1 = D_MED_M2) ///
>          (D_MED_M2 = D_MED_M3) ///
>          (D_MED_M3 = D_MED_M4) ///
>          (D_MED_M4 = D_MED_M5F)
 11.     local F_med_7 = r(F)
 12.     local p_med_7 = r(p)
 13. 
.     test (D_REC_P0 = D_REC_M1) ///
>          (D_REC_M1 = D_REC_M2) ///
>          (D_REC_M2 = D_REC_M3) ///
>          (D_REC_M3 = D_REC_M4) ///
>          (D_REC_M4 = D_REC_M5F)
 14.     local F_rec_7 = r(F)
 15.     local p_rec_7 = r(p)
 16. 
.     test (D_MED_P0 = D_MED_M1) ///
>          (D_MED_M1 = D_MED_M2) ///
>          (D_MED_M2 = D_MED_M3) ///
>          (D_MED_M3 = D_MED_M4) ///
>          (D_MED_M4 = D_MED_M5F) ///
>          (D_REC_P0 = D_REC_M1) ///
>          (D_REC_M1 = D_REC_M2) ///
>          (D_REC_M2 = D_REC_M3) ///
>          (D_REC_M3 = D_REC_M4) ///
>          (D_REC_M4 = D_REC_M5F)
 17.     local F_all_7 = r(F)
 18.     local p_all_7 = r(p)
 19. 
.     estimates restore `prefix'7
 20.     estadd scalar F_med = `F_med_7'
 21.     estadd scalar p_med = `p_med_7'
 22.     estadd scalar F_rec = `F_rec_7'
 23.     estadd scalar p_rec = `p_rec_7'
 24.     estadd scalar F_all = `F_all_7'
 25.     estadd scalar p_all = `p_all_7'
 26. 
.     * ---------------- Model 2 ----------------
.     di " "
 27.     di "Model 2: FE + covariates + linear state trends"
 28.     areg `varlist' $MEDvar $RECvar $tvar1 $xvar1 i.YEAR, absorb(FIPS) vce(robust)
 29.     estimates store `prefix'8
 30. 
.     test (D_MED_P0 = D_MED_M1) ///
>          (D_MED_M1 = D_MED_M2) ///
>          (D_MED_M2 = D_MED_M3) ///
>          (D_MED_M3 = D_MED_M4) ///
>          (D_MED_M4 = D_MED_M5F)
 31.     local F_med_8 = r(F)
 32.     local p_med_8 = r(p)
 33. 
.     test (D_REC_P0 = D_REC_M1) ///
>          (D_REC_M1 = D_REC_M2) ///
>          (D_REC_M2 = D_REC_M3) ///
>          (D_REC_M3 = D_REC_M4) ///
>          (D_REC_M4 = D_REC_M5F)
 34.     local F_rec_8 = r(F)
 35.     local p_rec_8 = r(p)
 36. 
.     test (D_MED_P0 = D_MED_M1) ///
>          (D_MED_M1 = D_MED_M2) ///
>          (D_MED_M2 = D_MED_M3) ///
>          (D_MED_M3 = D_MED_M4) ///
>          (D_MED_M4 = D_MED_M5F) ///
>          (D_REC_P0 = D_REC_M1) ///
>          (D_REC_M1 = D_REC_M2) ///
>          (D_REC_M2 = D_REC_M3) ///
>          (D_REC_M3 = D_REC_M4) ///
>          (D_REC_M4 = D_REC_M5F)
 37.     local F_all_8 = r(F)
 38.     local p_all_8 = r(p)
 39. 
.     estimates restore `prefix'8
 40.     estadd scalar F_med = `F_med_8'
 41.     estadd scalar p_med = `p_med_8'
 42.     estadd scalar F_rec = `F_rec_8'
 43.     estadd scalar p_rec = `p_rec_8'
 44.     estadd scalar F_all = `F_all_8'
 45.     estadd scalar p_all = `p_all_8'
 46. 
.     * ---------------- Model 3 ----------------
.     di " "
 47.     di "Model 3: FE + covariates + linear and quadratic state trends"
 48.     areg `varlist' $MEDvar $RECvar $tvar2 $xvar1 i.YEAR, absorb(FIPS) vce(robust)
 49.     estimates store `prefix'9
 50. 
.     test (D_MED_P0 = D_MED_M1) ///
>          (D_MED_M1 = D_MED_M2) ///
>          (D_MED_M2 = D_MED_M3) ///
>          (D_MED_M3 = D_MED_M4) ///
>          (D_MED_M4 = D_MED_M5F)
 51.     local F_med_9 = r(F)
 52.     local p_med_9 = r(p)
 53. 
.     test (D_REC_P0 = D_REC_M1) ///
>          (D_REC_M1 = D_REC_M2) ///
>          (D_REC_M2 = D_REC_M3) ///
>          (D_REC_M3 = D_REC_M4) ///
>          (D_REC_M4 = D_REC_M5F)
 54.     local F_rec_9 = r(F)
 55.     local p_rec_9 = r(p)
 56. 
.     test (D_MED_P0 = D_MED_M1) ///
>          (D_MED_M1 = D_MED_M2) ///
>          (D_MED_M2 = D_MED_M3) ///
>          (D_MED_M3 = D_MED_M4) ///
>          (D_MED_M4 = D_MED_M5F) ///
>          (D_REC_P0 = D_REC_M1) ///
>          (D_REC_M1 = D_REC_M2) ///
>          (D_REC_M2 = D_REC_M3) ///
>          (D_REC_M3 = D_REC_M4) ///
>          (D_REC_M4 = D_REC_M5F)
 57.     local F_all_9 = r(F)
 58.     local p_all_9 = r(p)
 59. 
.     estimates restore `prefix'9
 60.     estadd scalar F_med = `F_med_9'
 61.     estadd scalar p_med = `p_med_9'
 62.     estadd scalar F_rec = `F_rec_9'
 63.     estadd scalar p_rec = `p_rec_9'
 64.     estadd scalar F_all = `F_all_9'
 65.     estadd scalar p_all = `p_all_9'
 66. 
.     * On-screen compact table only
.     di " "
 67.     di "Compact coefficient table for `varlist':"
 68.     esttab `prefix'7 `prefix'8 `prefix'9, ///
>         keep($MEDvar $RECvar) ///
>         cells(b(star fmt(3)) t(par fmt(2))) ///
>         starlevels(* 0.10 ** 0.05 *** 0.01) ///
>         stats(ar2 F_med p_med F_rec p_rec F_all p_all, ///
>         fmt(4 2 3 2 3 2 3) ///
>         labels("adj. R2" "F eq. D_MED" "(p-value)" ///
>                "F eq. D_REC" "(p-value)" ///
>                "F eq. all D" "(p-value)"))
 69. end

. 
